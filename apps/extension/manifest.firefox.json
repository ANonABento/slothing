{
  "manifest_version": 2,
  "name": "Slothing - Job Application Assistant",
  "version": "1.0.0",
  "description": "Auto-fill job applications and import job listings from LinkedIn, Waterloo Works, and more",
  "browser_specific_settings": {
    "gecko": {
      "id": "slothing@slothing.work",
      "strict_min_version": "112.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.greenhouse.io/*",
    "*://boards.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://jobs.lever.co/*",
    "*://waterlooworks.uwaterloo.ca/*",
    "*://*.workdayjobs.com/*",
    "*://*.myworkdayjobs.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:3001/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.greenhouse.io/*",
        "*://boards.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://jobs.lever.co/*",
        "*://waterlooworks.uwaterloo.ca/*",
        "*://*.workdayjobs.com/*",
        "*://*.myworkdayjobs.com/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:3001/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": ["*.html", "*.css", "icons/*"],
  "commands": {
    "fill-form": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Auto-fill the current form"
    },
    "import-job": {
      "suggested_key": {
        "default": "Ctrl+Shift+I",
        "mac": "Command+Shift+I"
      },
      "description": "Import current job listing"
    }
  }
}
