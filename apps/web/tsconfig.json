{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@slothing/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@slothing/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/e2e/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../../packages/shared/src/**/*.test.ts",
    "../../packages/shared/src/**/*.spec.ts"
  ]
}
