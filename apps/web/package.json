{
  "name": "@slothing/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && node scripts/forbidden-color-lint.cjs && node scripts/forbidden-time-lint.cjs && node scripts/page-width-lint.cjs",
    "codex:terminal-probe": "node scripts/codex-terminal-probe.cjs",
    "pre-commit": "pnpm lint-staged && pnpm type-check",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:ui": "env -u NO_COLOR playwright test --ui",
    "test:e2e:headed": "env -u NO_COLOR playwright test --headed",
    "test:e2e:chromium": "env -u NO_COLOR playwright test --project=chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "eval": "npx tsx evals/harness.ts",
    "eval:resume": "npx tsx evals/harness.ts --mode=resume",
    "eval:cover-letter": "npx tsx evals/harness.ts --mode=cover-letter"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@libsql/client": "^0.14.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@react-pdf/renderer": "^3.4.4",
    "@slothing/shared": "workspace:*",
    "@tiptap/extension-bubble-menu": "^3.22.4",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-floating-menu": "^3.22.4",
    "@tiptap/extension-font-family": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.2",
    "googleapis": "^171.4.0",
    "libsql": "^0.4.7",
    "lucide-react": "^0.447.0",
    "mammoth": "^1.12.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^3.26.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^6.0.0",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.9",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.24",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8",
    "eslint-config-next": "14.2.21",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.1",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
