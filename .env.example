# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# libSQL/Turso Database
# Local default; use a Turso URL for hosted deployments. Auth token is optional for local file URLs.
TURSO_DATABASE_URL=file:./.local.db
TURSO_AUTH_TOKEN=

# LLM Providers (at least one required for AI features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Optional: Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Google Integration
# No env vars needed - uses Clerk OAuth for Google
# Configure Google scopes in Clerk Dashboard > Social Connections > Google
# See docs/DEVELOPER.md for setup instructions
