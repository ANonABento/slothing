# NextAuth.js Authentication
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (provider for NextAuth + direct Google API access)
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: enables email magic-link sign-in (in addition to Google).
# Sign up at https://resend.com -> API Keys.
# EMAIL_FROM must be a verified sender, formatted as "Name <addr@domain>".
RESEND_API_KEY=
EMAIL_FROM="Slothing <noreply@yourdomain.com>"

# Vercel cron auth - set in Vercel dashboard; cron handlers reject calls without it.
CRON_SECRET=

# Public flag mirroring NextAuth setup so client components can branch on it.
# Set to "true" once GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET are populated.
NEXT_PUBLIC_NEXTAUTH_ENABLED=

# libSQL/Turso Database
# Local default; use a Turso URL for hosted deployments. Auth token is optional for local file URLs.
TURSO_DATABASE_URL=file:./.local.db
TURSO_AUTH_TOKEN=

# LLM Providers (at least one required for AI features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Optional: Local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Calendar feed signing secret (HMAC for ICS feed tokens)
# Optional in dev; required in production.
CALENDAR_FEED_SECRET=

# Vercel Cron auth - required on production. Vercel attaches
# `Authorization: Bearer ${CRON_SECRET}` to scheduled requests.
# Generate with: openssl rand -base64 32
# Local dev: leave blank; cron routes are unauthenticated locally
# and warn on hit. CI: leave blank, tests stub it.
CRON_SECRET=
